{
  "name": "Rental Mobil Devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "settings": {
    "terminal.integrated.shell.linux": "/bin/bash"
  },
  "postCreateCommand": "pip install -r requirements.txt",
  "forwardPorts": [8000, 27017],
  "extensions": [
    "ms-python.python",
    "ms-python.vscode-pylance"
  ]
}
